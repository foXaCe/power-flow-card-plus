{
  "name": "power-flow-card-plus",
  "version": "0.43.2",
  "description": "A power flow card for Home Assistant",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "dashboard",
    "custom-cards"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foXaCe/power-flow-card-plus.git"
  },
  "author": "foXaCe",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/foXaCe/power-flow-card-plus/issues"
  },
  "homepage": "https://github.com/foXaCe/power-flow-card-plus#readme",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "release": "semantic-release",
    "start": "rollup -wc",
    "watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "audit:prod": "pnpm audit --prod",
    "validate": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "clean": "pnpm lint:fix && pnpm format:write && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2",
    "memoize-one": "^6.0.0",
    "sortablejs": "^1.15.7",
    "superstruct": "^1.0.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/eslint-plugin": "^7.27.1",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^30.3.0",
    "@open-wc/eslint-config": "^13.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-jest": "^30",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8",
    "eslint-plugin-lit": "^2",
    "eslint-plugin-lit-a11y": "^5",
    "eslint-plugin-no-only-tests": "^3",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.3",
    "rollup": "^4.30.0",
    "rollup-plugin-html-literals": "^2.0.1",
    "rollup-plugin-serve": "^3.0.0",
    "semantic-release": "^25.0.3",
    "semantic-release-replace-plugin": "^1.2.7",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6",
  "pnpm": {
    "overrides": {
      "handlebars": "^4.7.9",
      "minimatch@<3.1.3": "^3.1.5",
      "minimatch@>=5.0.0 <5.1.8": "^5.1.8",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "flatted": "^3.4.2",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "picomatch": "^2.3.2",
      "undici": "^6.25.0",
      "yaml": "^2.8.3",
      "serialize-javascript": "^7.0.5"
    }
  }
}
