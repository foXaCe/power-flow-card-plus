{
  "name": "power-flow-card-plus",
  "version": "0.45.3",
  "description": "A power flow card for Home Assistant",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "dashboard",
    "custom-cards"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foXaCe/power-flow-card-plus.git"
  },
  "author": "foXaCe",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/foXaCe/power-flow-card-plus/issues"
  },
  "homepage": "https://github.com/foXaCe/power-flow-card-plus#readme",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "release": "semantic-release",
    "start": "rollup -wc",
    "watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "audit:prod": "pnpm audit --prod",
    "validate": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "clean": "pnpm lint:fix && pnpm format:write && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.3",
    "memoize-one": "^6.0.0",
    "sortablejs": "^1.15.7",
    "superstruct": "^2.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/eslint-plugin": "^7.29.7",
    "@babel/preset-env": "^8.0.0",
    "@jest/globals": "^30.4.1",
    "@open-wc/eslint-config": "^13.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-jest": "^30.4.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.5",
    "rollup": "^4.62.2",
    "rollup-plugin-html-literals": "^2.0.1",
    "rollup-plugin-serve": "^3.0.0",
    "semantic-release": "^25.0.5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0"
}
